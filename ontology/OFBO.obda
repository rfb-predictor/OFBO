source		SELECT
			ID,
			SMILES,
			IUPACName,
			CoreSMILES,
			InChIKey,
			Diffusion_coefficient_CV  AS D_CV,
			Diffusion_coefficient_RDE AS D_RDE,
			k0_CV,
			k0_RDE,
			Redox_potential_pH14 AS E0_pH14,
			Peak_separation_mV        AS PeakSep_mV,
			Solubility_pH0            AS Sol_pH0,
			Solubility_pH7            AS Sol_pH7,
			Solubility_pH12           AS Sol_pH12
			FROM OFBO."10_1021acsenergylett_1c02504";

