[MappingDeclaration] @collection [[
mappingId	10_1002adfm_202312608
target		:202312608_{ID} a :Molecule ; :hasIUPACName {IUPACName}^^xsd:string ; :hasSMILES {SMILES}^^xsd:string ; :hasCoreSMILES {CoreSMILES}^^xsd:string ; :hasInChIKey {InChIKey}^^xsd:string ; :hasProperty :S_202312608_{ID} ; :hasReaction :RXN_202312608_{ID}_EXP . :RXN_202312608_{ID}_EXP a :ElectrochemicalReaction ; :isReactionOf :202312608_{ID} ; :hasProperty :E0_202312608_{ID}_EXP , :DeltaEp_202312608_{ID}_EXP , :IpaIpc_202312608_{ID}_EXP , :k0_202312608_{ID}_EXP , :D_202312608_{ID} . :E0_202312608_{ID}_EXP a :RedoxPotential ; :isPropertyOf :RXN_202312608_{ID}_EXP ; :hasValue {redox}^^xsd:decimal ; :hasReference "https://doi.org/10.1002/adfm.202312608"^^xsd:string ; :hasSolvent :Solv_202312608_{ID}_H2SO4 ; :hasMethod :CV_202312608_Experimental . :DeltaEp_202312608_{ID}_EXP a :PeakPotentialGap ; :isPropertyOf :RXN_202312608_{ID}_EXP ; :hasValue {delta_ep_mv}^^xsd:decimal ; :hasReference "https://doi.org/10.1002/adfm.202312608"^^xsd:string ; :hasSolvent :Solv_202312608_{ID}_H2SO4 ; :hasMethod :CV_202312608_Experimental . :IpaIpc_202312608_{ID}_EXP a :PeakCurrentRatio ; :isPropertyOf :RXN_202312608_{ID}_EXP ; :hasValue {ipa_ipc}^^xsd:decimal ; :hasReference "https://doi.org/10.1002/adfm.202312608"^^xsd:string ; :hasSolvent :Solv_202312608_{ID}_H2SO4 ; :hasMethod :CV_202312608_Experimental . :k0_202312608_{ID}_EXP a :HeterogeneousRateConstant ; :isPropertyOf :RXN_202312608_{ID}_EXP ; :hasValue {k0}^^xsd:decimal ; :hasReference "https://doi.org/10.1002/adfm.202312608"^^xsd:string ; :hasSolvent :Solv_202312608_{ID}_H2SO4 ; :hasMethod :LSV_202312608_Experimental . :D_202312608_{ID} a :DiffusionCoefficient ; :isPropertyOf :RXN_202312608_{ID}_EXP ; :hasValue {diffusion}^^xsd:decimal ; :hasReference "https://doi.org/10.1002/adfm.202312608"^^xsd:string ; :hasSolvent :Solv_202312608_{ID}_H2SO4 ; :hasMethod :LSV_202312608_Experimental . :S_202312608_{ID} a :Solubility ; :isPropertyOf :202312608_{ID} ; :hasValue {solubility}^^xsd:decimal ; :hasReference "https://doi.org/10.1002/adfm.202312608"^^xsd:string ; :hasSolvent :Solv_202312608_{ID}_H2SO4 ; :hasMethod :METH_SOL_202312608 . :Solv_202312608_{ID}_H2SO4 :hasPH "0"^^xsd:decimal ; :hasComposition "3M H2SO4"^^xsd:string . :CV_202312608_Experimental a :ExperimentalMethod ; :hasMethod <http://purl.obolibrary.org/obo/CHMO_0000025> . :LSV_202312608_Experimental a :ExperimentalMethod ; :hasMethod <http://purl.obolibrary.org/obo/CHMO_0000028> . :METH_SOL_202312608 a :ExperimentalMethod ; :hasMethod <http://purl.obolibrary.org/obo/CHMO_0001253> . 
source		SELECT
			ID,
			IUPACName, SMILES, CoreSMILES, InChIKey,
			"Redox_Potential(VvsSHE)" AS redox,
			"ΔEp[mV]" AS delta_ep_mv,
			"Ipa/Ipc" AS ipa_ipc,
			"D(10−6cm2s−1)" AS diffusion,
			"k0(10−3cms−1)" AS k0,
			"Solubility[molL−1]" AS solubility
			FROM OFBO."10_1002adfm_202312608"

mappingId	j_bbabio_2022_148558
target		:jbbabio_{ID} a :Molecule ; :hasIUPACName {IUPACName}^^xsd:string ; :hasSMILES {SMILES}^^xsd:string ; :hasCoreSMILES {CoreSMILES}^^xsd:string ; :hasInChIKey {InChIKey}^^xsd:string ; :hasReaction :RXN_jbbabio_{ID}_QQ , :RXN_jbbabio_{ID}_QQEQ . :Solv_jbbabio_{ID}_Aprotic :hasComposition "N,N-Dimethylformamide (DMF)"^^xsd:string . :METH_jbbabio_Experimental a :ExperimentalMethod ; :hasMethod <http://purl.obolibrary.org/obo/CHMO_0000025> . :RXN_jbbabio_{ID}_QQ a :ElectrochemicalReaction ; :isReactionOf :jbbabio_{ID} ; :hasNumberOfElectrons "1"^^xsd:integer ; :hasProperty :E0_jbbabio_{ID}_QQ . :RXN_jbbabio_{ID}_QQEQ a :ElectrochemicalReaction ; :isReactionOf :jbbabio_{ID} ; :hasNumberOfElectrons "2"^^xsd:integer ; :hasProperty :E0_jbbabio_{ID}_QQEQ . :E0_jbbabio_{ID}_QQ a :RedoxPotential ; :isPropertyOf :RXN_jbbabio_{ID}_QQ ; :hasValue {QQ_VvsNHE}^^xsd:decimal ; :hasSolvent :Solv_jbbabio_{ID}_Aprotic ; :hasReference "https://doi.org/10.1016/j.bbabio.2022.148558"^^xsd:string ; :hasMethod :METH_jbbabio_Experimental . :E0_jbbabio_{ID}_QQEQ a :RedoxPotential ; :isPropertyOf :RXN_jbbabio_{ID}_QQEQ ; :hasValue {QQeq_VvsNHE}^^xsd:decimal ; :hasSolvent :Solv_jbbabio_{ID}_Aprotic ; :hasReference "https://doi.org/10.1016/j.bbabio.2022.148558"^^xsd:string ; :hasMethod :METH_jbbabio_Experimental . 
source		SELECT
			ID,
			IUPACName,
			SMILES,
			CoreSMILES,
			InChIKey,
			"QQ.(VvsNHE)" AS QQ_VvsNHE,
			"Q.Q=(VvsNHE)" AS QQeq_VvsNHE
			FROM OFBO."j_bbabio_2022_148558"

mappingId	10_1039D1TA03655F
target		:1039D1TA03655F_{ID} a :Molecule ; :hasIUPACName {IUPACName}^^xsd:string ; :hasSMILES {SMILES}^^xsd:string ; :hasCoreSMILES {CoreSMILES}^^xsd:string ; :hasInChIKey {InChIKey}^^xsd:string ; :hasReaction :RXN_1039D1TA03655F_{ID}_EXP , :RXN_1039D1TA03655F_{ID}_DFT_B3LYP . :RXN_1039D1TA03655F_{ID}_EXP a :ElectrochemicalReaction ; :isReactionOf :1039D1TA03655F_{ID} ; :hasProperty :E0_1039D1TA03655F_{ID}_EXP , :DeltaEp_1039D1TA03655F_{ID}_EXP , :k0_1039D1TA03655F_{ID}_EXP , :D_1039D1TA03655F_{ID} . :E0_1039D1TA03655F_{ID}_EXP a :RedoxPotential ; :isPropertyOf :RXN_1039D1TA03655F_{ID}_EXP ; :hasValue {potential_nhe}^^xsd:decimal ; :hasReference "https://doi.org/10.1039/D1TA03655F"^^xsd:string ; :hasSolvent :Solv_1039D1TA03655F_{ID}_PH14 ; :hasMethod :METH_6b07558_Experimental . :DeltaEp_1039D1TA03655F_{ID}_EXP a :PeakPotentialGap ; :isPropertyOf :RXN_1039D1TA03655F_{ID}_EXP ; :hasValue {peak_sep_mv}^^xsd:decimal ; :hasReference "https://doi.org/10.1039/D1TA03655F"^^xsd:string ; :hasSolvent :Solv_1039D1TA03655F_{ID}_PH14 ; :hasMethod :METH_1039D1TA03655F_Experimental . :k0_1039D1TA03655F_{ID}_EXP a :HeterogeneousRateConstant ; :isPropertyOf :RXN_1039D1TA03655F_{ID}_EXP ; :hasValue {k0}^^xsd:decimal ; :hasReference "https://doi.org/10.1039/D1TA03655F"^^xsd:string ; :hasSolvent :Solv_1039D1TA03655F_{ID}_PH14 ; :hasMethod :METH_1039D1TA03655F_Experimental . :D_1039D1TA03655F_{ID} a :DiffusionCoefficient ; :isPropertyOf :RXN_1039D1TA03655F_{ID}_EXP ; :hasValue {diffusion}^^xsd:decimal ; :hasReference "https://doi.org/10.1039/D1TA03655F"^^xsd:string ; :hasSolvent :Solv_1039D1TA03655F_{ID}_PH14 ; :hasMethod :METH_1039D1TA03655F_Experimental . :RXN_1039D1TA03655F_{ID}_DFT_B3LYP a :ElectrochemicalReaction ; :isReactionOf :1039D1TA03655F_{ID} ; :hasProperty :E0_1039D1TA03655F_{ID}_DFT_B3LYP . :E0_1039D1TA03655F_{ID}_DFT_B3LYP a :RedoxPotential ; :isPropertyOf :RXN_1039D1TA03655F_{ID}_DFT_B3LYP ; :hasValue {calc_rp_14dhp}^^xsd:decimal ; :hasAdditionalInformation "vs 1,4-DHP"^^xsd:string ; :hasSolvent :Solv_1039D1TA03655F_{ID}_PH14 ; :hasMethod :METH_1039D1TA03655F_DFT_B3LYP . :Solv_1039D1TA03655F_{ID}_PH14 :hasComposition "1M NaOH"^^xsd:string ; :hasPH "14"^^xsd:decimal . :METH_1039D1TA03655F_Experimental a :ExperimentalMethod ; :hasMethod <http://purl.obolibrary.org/obo/CHMO_0000025> . :METH_1039D1TA03655F_DFT_B3LYP a :ComputationalMethod ; :hasMethod <https://w3id.org/mdo/calculation/DensityFunctionalTheoryMethod> , <https://w3id.org/mdo/calculation/HybridMetaGeneralizedGradientApproximation> ; :hasLevelOfTheory "B3LYP"^^xsd:string ; :hasInteraction :ImplicitSolvation . 
source		SELECT
			ID,
			IUPACName,
			SMILES,
			CoreSMILES, InChIKey,
			"Potential(VvsNHE)"   AS potential_nhe,
			"Calc_RP(Vvs14DHP)"   AS calc_rp_14dhp,
			"PeakSeparation(mV)"  AS peak_sep_mv,
			"D(cm2s−1)"           AS diffusion,
			"Ko(cms−1)"           AS k0
			FROM OFBO."10_1039D1TA03655F"

mappingId	10_1039C4SC03030C
target		:6b07558_{ID} a :Molecule ; :hasIUPACName {IUPACName}^^xsd:string ; :hasSMILES {SMILES}^^xsd:string ; :hasCoreSMILES {CoreSMILES}^^xsd:string ; :hasInChIKey {InChIKey}^^xsd:string ; :hasReaction :RXN_6b07558_{ID}_DFT_PBE ; :hasProperty :Gsolv_6b07558_{ID} . :RXN_6b07558_{ID}_DFT_PBE a :ElectrochemicalReaction ; :isReactionOf :6b07558_{ID} ; :hasProperty :E0_6b07558_{ID}_DFT_PBE . :E0_6b07558_{ID}_DFT_PBE a :RedoxPotential ; :isPropertyOf :RXN_6b07558_{ID}_DFT_PBE ; :hasValue {e0_she}^^xsd:decimal ; :hasMethod :METH_6b07558_PBE ; :hasReference "https://doi.org/10.1039/C4SC03030C"^^xsd:string . :Gsolv_6b07558_{ID} a :GibbsFreeEnergy ; :isPropertyOf :6b07558_{ID} ; :hasValue {g_solv}^^xsd:decimal ; :hasInteraction :INT_6b07558_{ID}_Implicit ; :hasMethod :METH_6b07558_PBE ; :hasReference "https://doi.org/10.1039/C4SC03030C"^^xsd:string . :INT_6b07558_{ID}_Implicit a :ImplicitSolvation ; :hasComposition "H2O"^^xsd:string . :METH_6b07558_PBE a :ComputationalMethod ; :hasMethod <https://w3id.org/mdo/calculation/GeneralizedGradientApproximation> , <https://w3id.org/mdo/calculation/DensityFunctionalTheoryMethod> ; :hasLevelOfTheory "PBE"^^xsd:string . 
source		SELECT
			ID,
			IUPACName,
			SMILES,
			CoreSMILES,
			State,
			InChIKey,
			"E0(VvsSHE)" AS e0_she,
			G_solv AS G_solv
			FROM OFBO."10_1039C4SC03030C"

mappingId	10_1021acs_jpcc_6b07558
target		:6b07558_{ID} a :Molecule ; :hasIUPACName {IUPACName}^^xsd:string ; :hasSMILES {SMILES}^^xsd:string ; :hasCoreSMILES {CoreSMILES}^^xsd:string ; :hasInChIKey {InChIKey}^^xsd:string ; :hasReaction :RXN_6b07558_{ID}_EXP . :RXN_6b07558_{ID}_EXP a :ElectrochemicalReaction ; :isReactionOf :6b07558_{ID} ; :hasProperty :E0_6b07558_{ID}_EXP , :E0_6b07558_{ID}_DFT_PCM , :E0_6b07558_{ID}_DFT_SM8 , :E0_6b07558_{ID}_QMMM . :E0_6b07558_{ID}_EXP a :RedoxPotential ; :isPropertyOf :RXN_6b07558_{ID}_EXP ; :hasValue {Expt}^^xsd:decimal ; :hasSolvent :SOLV_H2O ; :hasMethod :METH_6b07558_Experimental ; :hasReference "https://doi.org/10.1021/acs.jpcc.6b07558"^^xsd:string . :E0_6b07558_{ID}_DFT_PCM a :RedoxPotential ; :isPropertyOf :RXN_6b07558_{ID}_EXP ; :hasValue {DFT_PCM}^^xsd:decimal ; :hasSolvent :SOLV_H2O ; :hasMethod :METH_6b07558_PCM ; :hasReference "https://doi.org/10.1021/acs.jpcc.6b07558"^^xsd:string . :E0_6b07558_{ID}_DFT_SM8 a :RedoxPotential ; :isPropertyOf :RXN_6b07558_{ID}_EXP ; :hasValue {DFT_SM8}^^xsd:decimal ; :hasSolvent :SOLV_H2O ; :hasMethod :METH_6b07558_SM8 ; :hasReference "https://doi.org/10.1021/acs.jpcc.6b07558"^^xsd:string . :E0_6b07558_{ID}_QMMM a :RedoxPotential ; :isPropertyOf :RXN_6b07558_{ID}_EXP ; :hasValue {QMMM}^^xsd:decimal ; :hasSolvent :SOLV_H2O ; :hasMethod :METH_6b07558_QMMM ; :hasReference "https://doi.org/10.1021/acs.jpcc.6b07558"^^xsd:string . :SOLV_H2O :hasComposition "Water"^^xsd:string . :METH_6b07558_Experimental a :ExperimentalMethod . :METH_6b07558_PCM a :ComputationalMethod ; :hasMethod <https://w3id.org/mdo/calculation/DensityFunctionalTheoryMethod> , <https://w3id.org/mdo/calculation/HybridMetaGeneralizedGradientApproximation> ; :hasLevelOfTheory "DFT (PCM)"^^xsd:string . :METH_6b07558_SM8 a :ComputationalMethod ; :hasMethod <https://w3id.org/mdo/calculation/DensityFunctionalTheoryMethod> , <https://w3id.org/mdo/calculation/HybridMetaGeneralizedGradientApproximation> ; :hasLevelOfTheory "DFT (SM8)"^^xsd:string . :METH_6b07558_QMMM a :ComputationalMethod ; :hasMethod <https://w3id.org/mdo/calculation/QuantumMechanicsMolecularMechanicsMethod> ; :hasLevelOfTheory "QM/MM"^^xsd:string . 
source		SELECT
			ID,
			IUPACName,
			SMILES,
			CoreSMILES,
			InChIKey,
			"DFT(PCM)" AS DFT_PCM,
			"DFT(SM8)" AS DFT_SM8,
			"QM/MM"    AS QMMM,
			Expt
			FROM OFBO."10_1021acs_jpcc_6b07558"

mappingId	10_1021acs_chemmater_7b04220
target		:7b04220_{ID} a :Molecule ; :hasIUPACName {IUPACName}^^xsd:string ; :hasSMILES {SMILES}^^xsd:string ; :hasCoreSMILES {CoreSMILES}^^xsd:string ; :hasInChIKey {InChIKey}^^xsd:string ; :hasReaction :RXN_7b04220_{ID}_EXP , :RXN_7b04220_{ID}_DFT_PROT , :RXN_7b04220_{ID}_DFT_NEUT , :RXN_7b04220_{ID}_DFT_DEPROT . :7b04220_{ID}_DFT_PROT_R a :Molecule ; :hasSMILES {SMILES_prot_ox}^^xsd:string . :7b04220_{ID}_DFT_PROT_P a :Molecule ; :hasSMILES {SMILES_prot_red}^^xsd:string . :7b04220_{ID}_DFT_NEUT_R a :Molecule ; :hasSMILES {SMILES_ox}^^xsd:string . :7b04220_{ID}_DFT_NEUT_P a :Molecule ; :hasSMILES {SMILES_red}^^xsd:string . :7b04220_{ID}_DFT_DEPROT_R a :Molecule ; :hasSMILES {SMILES_deprot_ox}^^xsd:string . :7b04220_{ID}_DFT_DEPROT_P a :Molecule ; :hasSMILES {SMILES_deprot_red}^^xsd:string . :RXN_7b04220_{ID}_EXP a :ElectrochemicalReaction ; :isReactionOf :7b04220_{ID} ; :hasProperty :E0_7b04220_{ID}_pH0_EXP , :E0_7b04220_{ID}_pH14_EXP , :DIF_7b04220_{ID}_pH0 , :K0_7b04220_{ID}_pH0_EXP . :DIF_7b04220_{ID}_pH0 a :DiffusionCoefficient ; :isPropertyOf :RXN_7b04220_{ID}_EXP ; :hasValue {D_cm2_s}^^xsd:decimal ; :hasSolvent :SOLV_pH0_7b04220 ; :hasMethod :METH_7b04220_Experimental ; :hasReference "https://doi.org/10.1021/acs.chemmater.7b04220"^^xsd:string . :E0_7b04220_{ID}_pH0_EXP a :RedoxPotential ; :isPropertyOf :RXN_7b04220_{ID}_EXP ; :hasValue {E0_pH0_exp}^^xsd:decimal ; :hasSolvent :SOLV_pH0_7b04220 ; :hasMethod :METH_7b04220_Experimental ; :hasReference "https://doi.org/10.1021/acs.chemmater.7b04220"^^xsd:string . :E0_7b04220_{ID}_pH14_EXP a :RedoxPotential ; :isPropertyOf :RXN_7b04220_{ID}_EXP ; :hasValue {E0_pH14_exp}^^xsd:decimal ; :hasSolvent :SOLV_pH0_7b04220 ; :hasMethod :METH_7b04220_Experimental ; :hasReference "https://doi.org/10.1021/acs.chemmater.7b04220"^^xsd:string . :K0_7b04220_{ID}_pH0_EXP a :HeterogeneousRateConstant ; :isPropertyOf :RXN_7b04220_{ID}_EXP ; :hasValue {k0_cm_s}^^xsd:decimal ; :hasSolvent :SOLV_pH0_7b04220 ; :hasMethod :METH_7b04220_Experimental ; :hasReference "https://doi.org/10.1021/acs.chemmater.7b04220"^^xsd:string . :RXN_7b04220_{ID}_DFT_PROT a :ElectrochemicalReaction ; :isReactionOf :7b04220_{ID} ; :hasReactant :7b04220_{ID}_DFT_PROT_R ; :hasProduct :7b04220_{ID}_DFT_PROT_P ; :hasProperty :E0_7b04220_{ID}_DFT_PROT . :E0_7b04220_{ID}_DFT_PROT a :RedoxPotential ; :isPropertyOf :RXN_7b04220_{ID}_DFT_PROT ; :hasValue {E0_prot_dft}^^xsd:decimal ; :hasSolvent :SOLV_H2O_7b04220 ; :hasMethod :METH_7b04220_BP86_D3 ; :hasReference "https://doi.org/10.1021/acs.chemmater.7b04220"^^xsd:string . :RXN_7b04220_{ID}_DFT_NEUT a :ElectrochemicalReaction ; :isReactionOf :7b04220_{ID} ; :hasReactant :7b04220_{ID}_DFT_NEUT_R ; :hasProduct :7b04220_{ID}_DFT_NEUT_P ; :hasProperty :E0_7b04220_{ID}_DFT_NEUT . :E0_7b04220_{ID}_DFT_NEUT a :RedoxPotential ; :isPropertyOf :RXN_7b04220_{ID}_DFT_NEUT ; :hasValue {E0_dft}^^xsd:decimal ; :hasSolvent :SOLV_H2O_7b04220 ; :hasMethod :METH_7b04220_BP86_D3 ; :hasReference "https://doi.org/10.1021/acs.chemmater.7b04220"^^xsd:string . :RXN_7b04220_{ID}_DFT_DEPROT a :ElectrochemicalReaction ; :isReactionOf :7b04220_{ID} ; :hasReactant :7b04220_{ID}_DFT_DEPROT_R ; :hasProduct :7b04220_{ID}_DFT_DEPROT_P ; :hasProperty :E0_7b04220_{ID}_DFT_DEPROT . :E0_7b04220_{ID}_DFT_DEPROT a :RedoxPotential ; :isPropertyOf :RXN_7b04220_{ID}_DFT_DEPROT ; :hasValue {E0_deprot_dft}^^xsd:decimal ; :hasSolvent :SOLV_H2O_7b04220 ; :hasMethod :METH_7b04220_BP86_D3 ; :hasReference "https://doi.org/10.1021/acs.chemmater.7b04220"^^xsd:string . :SOLV_H2O_7b04220 :hasComposition "water"^^xsd:string . :SOLV_pH14_7b04220 :hasPH "14"^^xsd:decimal ; :hasComposition "1 M KOH"^^xsd:string . :SOLV_pH0_7b04220 :hasPH "0"^^xsd:decimal ; :hasComposition "2 M H2SO4"^^xsd:string . :METH_7b04220_Experimental a :ExperimentalMethod ; :hasMethod <http://purl.obolibrary.org/obo/CHMO_0000025> . :METH_7b04220_BP86_D3 a :ComputationalMethod ; :hasMethod <https://w3id.org/mdo/calculation/GeneralizedGradientApproximation> , <https://w3id.org/mdo/calculation/DensityFunctionalTheoryMethod> ; :hasLevelOfTheory "BP86+D3"^^xsd:string . 
source		SELECT
			ID,
			IUPACName,
			SMILES,
			CoreSMILES,
			State,
			InChIKey,
			"D_[cm2/s]" AS D_cm2_s,
			"k0_[cm/s]" AS k0_cm_s,
			"E1/2_(pH=0)[VvsSHE]exprimental" AS E0_pH0_exp,
			"E1/2(pH=14)[VvsSHE]experimental" AS E0_pH14_exp,
			SMILES_prot_ox,
			SMILES_prot_red,
			E0_prot_dft,
			SMILES_ox,
			SMILES_red,
			E0_dft,
			SMILES_deprot_ox,
			SMILES_deprot_red,
			E0_deprot_dft
			FROM OFBO."10_1021acs_chemmater_7b04220"

mappingId	10_1039D0SE00687D
